{
  "name": "@ci-test/benchmark",
  "private": "true",
  "type": "module",
  "scripts": {
    "clean:report": "node scripts/clean-report.mjs",
    "build:app": "pnpm -C ../../mf-test run build",
    "test:e2e": "playwright test",
    "lhci": "node scripts/run-lhci-with-chrome.cjs",
    "data:extract-lh": "node scripts/extract-lighthouse.mjs",
    "data:summary": "node scripts/build-summary.mjs",
    "report:dashboard": "node scripts/make-dashboard.mjs",
    "benchmark": "pnpm run clean:report && pnpm run build:app && pnpm run test:e2e && pnpm run lhci && pnpm run data:extract-lh && pnpm run data:summary && pnpm run report:dashboard"
  },
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.17.0"
  }
}
